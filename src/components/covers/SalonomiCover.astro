---
interface Props {
  title?: string;
  size?: 'sm' | 'lg';
}
const { title = 'Salonomi', size = 'sm' } = Astro.props;
const titleSize = size === 'lg' ? 'text-6xl md:text-9xl' : 'text-4xl md:text-7xl';
---

<div class="relative w-full h-full overflow-hidden flex items-center justify-center" style="background: radial-gradient(ellipse at 30% 20%, #9D6FFF 0%, #6B2DE6 60%, #4A1FA8 100%);">
	<div class="absolute top-5 left-5 text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-white/70 font-bold">UX/UI · Product</div>
	<h2 class={`${titleSize} italic font-serif font-medium text-white text-center leading-none px-4`}>{title}</h2>
	<div class="absolute bottom-5 right-5 text-[9px] md:text-[10px] uppercase tracking-[0.3em] text-white/70 font-bold">2024</div>
	<svg class="absolute top-6 right-6 w-5 h-5 md:w-7 md:h-7 text-white/40" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
		<path d="M16 1.5 C16.6 11.2 20.8 15.4 30.5 16 C20.8 16.6 16.6 20.8 16 30.5 C15.4 20.8 11.2 16.6 1.5 16 C11.2 15.4 15.4 11.2 16 1.5 Z"/>
	</svg>
	<svg class="absolute bottom-8 left-6 w-3 h-3 md:w-4 md:h-4 text-white/30" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
		<path d="M16 1.5 C16.6 11.2 20.8 15.4 30.5 16 C20.8 16.6 16.6 20.8 16 30.5 C15.4 20.8 11.2 16.6 1.5 16 C11.2 15.4 15.4 11.2 16 1.5 Z"/>
	</svg>
</div>
