---
interface Props {
  size?: 'sm' | 'lg';
}
const { size = 'sm' } = Astro.props;

const titleSize = size === 'lg' ? 'text-7xl md:text-9xl' : 'text-4xl md:text-6xl';
const eyebrowSize = size === 'lg' ? 'text-[10px] md:text-xs' : 'text-[9px] md:text-[10px]';
const swatchSize = size === 'lg' ? 'w-6 h-6 md:w-8 md:h-8' : 'w-3 h-3 md:w-4 md:h-4';
---

<div class="relative w-full h-full overflow-hidden flex flex-col justify-between bg-[#F9F8F3] p-5 md:p-8">
	<!-- Top row: eyebrow left, sparkle right -->
	<div class="flex justify-between items-start">
		<div class={`${eyebrowSize} uppercase tracking-[0.3em] text-gray-400 font-bold`}>Portfolio & Design System</div>
		<svg class="w-4 h-4 md:w-5 md:h-5 text-[#E0A4B0]" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
			<path d="M16 1.5 C16.6 11.2 20.8 15.4 30.5 16 C20.8 16.6 16.6 20.8 16 30.5 C15.4 20.8 11.2 16.6 1.5 16 C11.2 15.4 15.4 11.2 16 1.5 Z"/>
		</svg>
	</div>

	<!-- Center: title -->
	<div class="flex-1 flex items-center justify-center">
		<h2 class={`${titleSize} font-serif font-medium text-gray-900 text-center leading-[0.95]`}>
			Portfolio<br/><em class="text-[#E0A4B0]">by Jeka</em>
		</h2>
	</div>

	<!-- Bottom row: swatches left, eyebrow right -->
	<div class="flex justify-between items-end">
		<div class="flex gap-1.5">
			<div class={`${swatchSize} bg-[#F9F8F3] border border-black/15`}></div>
			<div class={`${swatchSize} bg-black`}></div>
			<div class={`${swatchSize} bg-[#E0A4B0]`}></div>
			<div class={`${swatchSize} bg-gray-400`}></div>
		</div>
		<div class={`${eyebrowSize} uppercase tracking-[0.3em] text-gray-400 font-bold text-right`}>Built with Claude · 2026</div>
	</div>
</div>
