---
import BaseLayout from '../layouts/BaseLayout.astro';

const email = 'jekaduran9@gmail.com';
const socials = [
	{ label: 'LinkedIn', handle: 'in/jessicaduranru', url: 'https://www.linkedin.com/in/jessicaduranru/' },
	{ label: 'Instagram', handle: '@_byjeka', url: 'https://instagram.com/_byjeka' },
	{ label: 'Behance', handle: 'jessicadurn', url: 'https://www.behance.net/jessicadurn' },
];
---

<BaseLayout title="Contacto">
	<section class="max-w-7xl mx-auto px-6 py-24 md:py-32">
		<div class="grid md:grid-cols-2 gap-16 md:gap-24 items-start">

			<div class="space-y-10 md:pt-12">
				<span class="text-xs uppercase tracking-[0.25em] text-gray-400 font-bold">Contacto</span>
				<h1 class="font-serif text-6xl md:text-8xl leading-[0.95] tracking-tight">
					<span class="italic">Trabajemos</span><br />
					juntos<svg class="inline-block w-7 h-7 md:w-10 md:h-10 ml-2 align-top mt-2 md:mt-4 text-gray-900" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 1.5 C16.6 11.2 20.8 15.4 30.5 16 C20.8 16.6 16.6 20.8 16 30.5 C15.4 20.8 11.2 16.6 1.5 16 C11.2 15.4 15.4 11.2 16 1.5 Z"/></svg>
				</h1>
				<div class="text-lg text-gray-600 leading-relaxed max-w-md space-y-4">
					<p>
						Si tienes un proyecto en mente, una idea por validar o solo quieres saludar, me encantaría escucharte.
					</p>
					<p>
						Respondo cada mensaje personalmente — sin formularios, sin filtros. Escríbeme directamente.
					</p>
				</div>
				<p class="font-serif italic text-3xl text-[#E0A4B0] pt-2">— Jeka</p>
			</div>

			<div class="space-y-14 md:pt-12">
				<div class="inline-flex items-center gap-3 px-4 py-2 border border-gray-300 rounded-full text-[11px] uppercase tracking-[0.2em] font-medium">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-60"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
					</span>
					Disponible para freelance
				</div>

				<div class="space-y-4">
					<span class="block text-xs uppercase tracking-[0.25em] text-gray-400 font-bold">Email</span>
					<a
						href={`mailto:${email}`}
						class="block font-serif italic text-3xl md:text-5xl break-all leading-tight hover:text-gray-400 transition-colors"
					>
						{email}
					</a>
					<button
						type="button"
						data-copy={email}
						class="copy-btn group inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-gray-500 hover:text-black transition-colors mt-2"
					>
						<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
							<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
						</svg>
						<span class="copy-label">Copiar</span>
					</button>
				</div>

				<div class="space-y-4">
					<span class="block text-xs uppercase tracking-[0.25em] text-gray-400 font-bold">En otros lugares</span>
					<ul class="border-t border-gray-200">
						{socials.map((s) => (
							<li class="border-b border-gray-200">
								<a
									href={s.url}
									target="_blank"
									rel="noopener noreferrer"
									class="group flex items-center justify-between py-5 hover:pl-2 transition-all duration-300"
								>
									<span class="text-base font-medium">{s.label}</span>
									<span class="flex items-center gap-4 text-sm text-gray-500 group-hover:text-black transition-colors">
										{s.handle}
										<span class="inline-block transition-transform duration-300 group-hover:translate-x-1">→</span>
									</span>
								</a>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</section>

	<script is:inline define:vars={{ copiedLabel: '¡Copiado!', defaultLabel: 'Copiar' }}>
		document.querySelectorAll('.copy-btn').forEach((btn) => {
			btn.addEventListener('click', async () => {
				const value = btn.getAttribute('data-copy');
				if (!value) return;
				try {
					await navigator.clipboard.writeText(value);
				} catch {
					return;
				}
				const label = btn.querySelector('.copy-label');
				if (!label) return;
				label.textContent = copiedLabel;
				setTimeout(() => { label.textContent = defaultLabel; }, 2000);
			});
		});
	</script>
</BaseLayout>
