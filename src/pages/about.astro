---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  { company: "Empresa A", role: "Senior Product Designer", period: "2022 — Presente" },
  { company: "Estudio Digital B", role: "UX/UI Designer", period: "2020 — 2022" },
  { company: "Startup C", role: "Junior Designer", period: "2018 — 2020" },
];

const services = [
  "UX Research",
  "UX/UI Design",
  "Product Design",
  "Design Systems",
  "Prototyping",
  "Web Design"
];
---

<BaseLayout title="About Me">
	<section class="max-w-7xl mx-auto px-6 py-24 md:py-32">
		<div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-start">
			<div class="aspect-[4/5] bg-gray-100 flex items-center justify-center text-gray-400 font-serif italic text-2xl overflow-hidden">
				Photo Placeholder
			</div>
			
			<div class="space-y-12">
				<div class="space-y-6">
					<h1 class="text-4xl font-medium tracking-tight">Hola, soy Jessica. Una apasionada por el diseño centrado en las personas.</h1>
					<p class="text-lg text-gray-500 leading-relaxed">
						Con más de 5 años de experiencia creando productos digitales, mi enfoque combina la investigación profunda con una ejecución visual elegante. Creo que los mejores diseños son aquellos que resuelven problemas reales de forma invisible.
					</p>
					<p class="text-lg text-gray-500 leading-relaxed">
						He trabajado con startups y grandes empresas para transformar ideas complejas en interfaces intuitivas y funcionales.
					</p>
				</div>

				<div class="space-y-8">
					<h2 class="text-xs uppercase tracking-[0.2em] text-gray-400 font-bold">Experiencia</h2>
					<div class="space-y-6">
						{experience.map(item => (
							<div class="flex justify-between items-baseline border-b border-gray-100 pb-4">
								<div>
									<h3 class="font-medium">{item.company}</h3>
									<p class="text-sm text-gray-400">{item.role}</p>
								</div>
								<span class="text-xs font-medium text-gray-400 uppercase">{item.period}</span>
							</div>
						))}
					</div>
				</div>

				<div class="space-y-8">
					<h2 class="text-xs uppercase tracking-[0.2em] text-gray-400 font-bold">Servicios</h2>
					<div class="flex flex-wrap gap-3">
						{services.map(service => (
							<span class="px-4 py-2 border border-gray-200 text-sm font-medium hover:bg-black hover:text-white transition-colors cursor-default">
								{service}
							</span>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
