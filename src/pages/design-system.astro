---
import BaseLayout from '../layouts/BaseLayout.astro';
import SalonomiCover from '../components/covers/SalonomiCover.astro';
import ElNoiCover from '../components/covers/ElNoiCover.astro';
import SalonTattooCover from '../components/covers/SalonTattooCover.astro';

const lastUpdated = '28 de abril, 2026';

const colorTokens = {
  base: [
    { name: 'Fondo principal', hex: '#F9F8F3', tw: 'bg-[#F9F8F3]', use: 'Body, header (con blur), footer' },
    { name: 'Acento primario', hex: '#E0A4B0', tw: 'bg-[#E0A4B0]', use: 'Estrella, hovers, links activos, filtro activo' },
    { name: 'Tinta principal', hex: '#111827', tw: 'bg-gray-900', use: 'Texto principal, títulos sobre fondo claro' },
    { name: 'Blanco', hex: '#FFFFFF', tw: 'bg-white', use: 'Fondo de cards, texto sobre covers oscuros' },
    { name: 'Negro puro', hex: '#000000', tw: 'bg-black', use: 'Cover SalonTattoo, selección de texto' },
  ],
  grays: [
    { name: 'Gray 300', hex: '#D1D5DB', tw: 'bg-gray-300', use: 'Bordes de tags, separadores' },
    { name: 'Gray 400', hex: '#9CA3AF', tw: 'bg-gray-400', use: 'Labels muted, captions' },
    { name: 'Gray 500', hex: '#6B7280', tw: 'bg-gray-500', use: 'Texto labels, placeholders' },
    { name: 'Gray 600', hex: '#4B5563', tw: 'bg-gray-600', use: 'Body principal' },
    { name: 'Gray 800', hex: '#1F2937', tw: 'bg-gray-800', use: 'Texto oscuro secundario' },
    { name: 'Gray 900', hex: '#111827', tw: 'bg-gray-900', use: 'Títulos, énfasis' },
  ],
  states: [
    { name: 'Status verde', hex: '#22C55E', tw: 'bg-green-500', use: 'Punto "disponible" con animate-ping' },
    { name: 'Emerald (contacto)', hex: '#10B981', tw: 'bg-emerald-500', use: 'Pill "disponible para freelance"' },
    { name: 'Borde sutil', hex: '#000000 @ 5%', tw: 'border-black/5', use: 'Header bottom, divisores de sección' },
    { name: 'Borde medio', hex: '#000000 @ 10%', tw: 'border-black/10', use: 'Separador del language toggle' },
  ],
};

const typeWeights = [
  { weight: 300, name: 'Light' },
  { weight: 400, name: 'Regular' },
  { weight: 500, name: 'Medium' },
  { weight: 600, name: 'Semibold' },
  { weight: 700, name: 'Bold' },
];

const trackingScale = [
  { value: '0.15em', use: 'Servicios (badges), nav items' },
  { value: '0.2em', use: 'CTA principales, navegación' },
  { value: '0.25em', use: 'Featured project tags' },
  { value: '0.3em', use: 'Captions pequeñas (10–11px)' },
  { value: '0.4em', use: 'Subtítulos en covers' },
];

const spacingScale = [
  { token: 'p-1', px: 4 },
  { token: 'p-2', px: 8 },
  { token: 'p-3', px: 12 },
  { token: 'p-4', px: 16 },
  { token: 'p-6', px: 24 },
  { token: 'p-8', px: 32 },
  { token: 'p-12', px: 48 },
  { token: 'p-16', px: 64 },
  { token: 'p-20', px: 80 },
  { token: 'p-24', px: 96 },
  { token: 'p-32', px: 128 },
];

const radii = [
  { token: 'rounded-sm', value: '2px', use: 'Imágenes de proyecto, snippets de código' },
  { token: 'rounded-[8px]', value: '8px', use: 'Imagen interna del ProjectCard' },
  { token: 'rounded-[12px]', value: '12px', use: 'ProjectCard contenedor' },
  { token: 'rounded-full', value: '9999px', use: 'Botones CTA, badges, status dots' },
];

const containers = [
  { token: 'max-w-sm', px: 384, use: 'Texto del footer' },
  { token: 'max-w-md', px: 448, use: 'Descripción about' },
  { token: 'max-w-xl', px: 576, use: 'Descripción featured project' },
  { token: 'max-w-6xl', px: 1152, use: 'Artículo de proyecto' },
  { token: 'max-w-7xl', px: 1280, use: 'Contenedor principal del sitio' },
];

const tocLinks = [
  { href: '#color', label: '01 — Color' },
  { href: '#tipografia', label: '02 — Tipografía' },
  { href: '#componentes', label: '03 — Componentes' },
  { href: '#espaciado', label: '04 — Espaciado y layout' },
  { href: '#iconografia', label: '05 — Iconografía' },
  { href: '#animacion', label: '06 — Animación' },
  { href: '#brand', label: '07 — Brand assets' },
];

const sparklePath = 'M16 1.5 C16.6 11.2 20.8 15.4 30.5 16 C20.8 16.6 16.6 20.8 16 30.5 C15.4 20.8 11.2 16.6 1.5 16 C11.2 15.4 15.4 11.2 16 1.5 Z';
---

<BaseLayout title="Design System">
  <article class="max-w-7xl mx-auto px-6 py-24 md:py-32">

    <!-- ═══════════════════════════════════════════════
         CABECERA + ÍNDICE
         ═══════════════════════════════════════════════ -->
    <header class="mb-24 md:mb-32">
      <span class="text-xs uppercase tracking-[0.25em] text-gray-400 font-bold block mb-6">
        Documento vivo · v1.0
      </span>
      <h1 class="font-serif text-6xl md:text-8xl leading-[0.95] tracking-tight text-gray-900">
        <span class="italic">Design</span><br />
        System<svg class="inline-block w-7 h-7 md:w-10 md:h-10 ml-2 align-top mt-2 md:mt-4 text-[#E0A4B0]" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d={sparklePath} /></svg>
      </h1>
      <p class="text-xl italic font-serif font-light text-gray-600 leading-relaxed max-w-2xl mt-10">
        Una guía visual de los tokens, componentes y patrones que definen el portfolio. Esta página renderiza los tokens reales del sitio: cualquier cambio en el código se refleja aquí automáticamente.
      </p>
      <p class="text-base text-gray-500 leading-relaxed max-w-2xl mt-4">
        Úsalo como referencia al añadir secciones nuevas, modificar componentes o validar la coherencia visual. Si necesitas un nuevo token, edítalo en su origen (Tailwind, <code class="font-mono text-[12px] bg-gray-100 px-1.5 py-0.5 rounded-sm">global.css</code> o el componente correspondiente) y revisa cómo se ve aquí antes de publicar.
      </p>

      <div class="mt-16 pt-10 border-t border-black/5">
        <span class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold block mb-6">Índice</span>
        <nav class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-3">
          {tocLinks.map(link => (
            <a href={link.href} class="text-sm font-medium text-gray-700 hover:text-[#E0A4B0] transition-colors flex items-center justify-between border-b border-gray-100 pb-3">
              <span>{link.label}</span>
              <span class="text-gray-300">→</span>
            </a>
          ))}
        </nav>
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mt-10">
          Última actualización · {lastUpdated}
        </p>
      </div>
    </header>

    <!-- ═══════════════════════════════════════════════
         01 · COLOR
         ═══════════════════════════════════════════════ -->
    <section id="color" class="py-16 md:py-24 border-t border-black/5 scroll-mt-24">
      <div class="mb-12">
        <span class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold block mb-4">01</span>
        <h2 class="font-serif italic text-4xl md:text-6xl font-medium text-gray-900 leading-tight">Color</h2>
        <p class="text-base text-gray-600 leading-relaxed max-w-xl mt-4">
          Paleta minimalista construida sobre un fondo crema con un único acento rosa que actúa como firma visual. Los grises se usan en escala progresiva para crear jerarquía sin recurrir a más colores.
        </p>
      </div>

      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Base</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-16">
        {colorTokens.base.map(c => (
          <div class="group">
            <div class="aspect-square rounded-[8px] border border-black/5 mb-3 transition-transform duration-300 group-hover:scale-[1.03]" style={`background-color: ${c.hex};`}></div>
            <p class="text-sm font-medium text-gray-900">{c.name}</p>
            <p class="font-mono text-[11px] text-gray-500 mt-0.5">{c.hex}</p>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm inline-block mt-1">{c.tw}</code>
            <p class="text-[11px] text-gray-500 leading-snug mt-2">{c.use}</p>
          </div>
        ))}
      </div>

      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Escala de grises</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-16">
        {colorTokens.grays.map(c => (
          <div class="group">
            <div class="aspect-square rounded-[8px] border border-black/5 mb-3 transition-transform duration-300 group-hover:scale-[1.03]" style={`background-color: ${c.hex};`}></div>
            <p class="text-sm font-medium text-gray-900">{c.name}</p>
            <p class="font-mono text-[11px] text-gray-500 mt-0.5">{c.hex}</p>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm inline-block mt-1">{c.tw}</code>
            <p class="text-[11px] text-gray-500 leading-snug mt-2">{c.use}</p>
          </div>
        ))}
      </div>

      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Estados y bordes</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
        {colorTokens.states.map(c => (
          <div>
            <div class="aspect-square rounded-[8px] border border-gray-200 mb-3" style={c.tw.startsWith('border-') ? `border: 1px solid ${c.hex.includes('@') ? 'rgba(0,0,0,0.1)' : c.hex}; background: #FAFAFA;` : `background-color: ${c.hex};`}></div>
            <p class="text-sm font-medium text-gray-900">{c.name}</p>
            <p class="font-mono text-[11px] text-gray-500 mt-0.5">{c.hex}</p>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm inline-block mt-1">{c.tw}</code>
            <p class="text-[11px] text-gray-500 leading-snug mt-2">{c.use}</p>
          </div>
        ))}
      </div>

      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Gradientes de portada</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <div class="aspect-[4/3] rounded-[8px] overflow-hidden mb-3">
            <SalonomiCover title="Salonomi" />
          </div>
          <p class="text-sm font-medium">Salonomi</p>
          <p class="text-[11px] text-gray-500 leading-snug mt-1">
            <code class="font-mono text-[10px] bg-gray-100 px-1 rounded-sm break-all">radial-gradient(ellipse at 30% 20%, #9D6FFF 0%, #6B2DE6 60%, #4A1FA8 100%)</code>
          </p>
        </div>
        <div>
          <div class="aspect-[4/3] rounded-[8px] overflow-hidden mb-3">
            <ElNoiCover title="El Noi del Pa" />
          </div>
          <p class="text-sm font-medium">El Noi del Pa</p>
          <p class="text-[11px] text-gray-500 leading-snug mt-1">
            <code class="font-mono text-[10px] bg-gray-100 px-1 rounded-sm break-all">linear-gradient(160deg, #9C6F4F 0%, #7A4F35 60%, #5A3823 100%)</code>
          </p>
        </div>
        <div>
          <div class="aspect-[4/3] rounded-[8px] overflow-hidden mb-3">
            <SalonTattooCover title="By Jeka" />
          </div>
          <p class="text-sm font-medium">By Jeka (Tattoo)</p>
          <p class="text-[11px] text-gray-500 leading-snug mt-1">
            Negro puro <code class="font-mono text-[10px] bg-gray-100 px-1 rounded-sm">#000</code> + patrón de puntos blancos al 6% de opacidad.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         02 · TIPOGRAFÍA
         ═══════════════════════════════════════════════ -->
    <section id="tipografia" class="py-16 md:py-24 border-t border-black/5 scroll-mt-24">
      <div class="mb-12">
        <span class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold block mb-4">02</span>
        <h2 class="font-serif italic text-4xl md:text-6xl font-medium text-gray-900 leading-tight">Tipografía</h2>
        <p class="text-base text-gray-600 leading-relaxed max-w-xl mt-4">
          Dos familias en contraste claro: <strong class="font-medium">Cormorant Garamond</strong> (serif editorial, italic predominante) para el lenguaje cálido y narrativo, e <strong class="font-medium">Inter</strong> (sans neutra) para todo lo funcional — UI, labels, captions y body técnico.
        </p>
      </div>

      <!-- Familias -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-20">
        <div class="bg-white rounded-[12px] p-8 border border-black/5">
          <span class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold block mb-4">Serif · Editorial</span>
          <p class="font-serif italic text-7xl text-gray-900 leading-none mb-3">Aa</p>
          <p class="font-serif text-2xl text-gray-700 mb-1">Cormorant Garamond</p>
          <p class="font-mono text-[11px] text-gray-500 mb-4">--font-serif</p>
          <p class="font-serif text-base text-gray-600 leading-relaxed">
            ABCDEFGHIJKLMNÑOPQRSTUVWXYZ<br />
            abcdefghijklmnñopqrstuvwxyz<br />
            0123456789 &amp;.,!?¿—
          </p>
          <p class="text-[11px] text-gray-500 mt-4">Pesos: 300, 400, 500, 600, 700 · regular e italic</p>
          <p class="text-[11px] text-gray-500 mt-1"><strong class="font-medium text-gray-700">Uso:</strong> H1, H2, citas, body editorial. Casi siempre <em>italic</em>.</p>
        </div>

        <div class="bg-white rounded-[12px] p-8 border border-black/5">
          <span class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold block mb-4">Sans · UI</span>
          <p class="font-sans text-7xl text-gray-900 leading-none mb-3 font-medium">Aa</p>
          <p class="font-sans text-2xl text-gray-700 mb-1 font-medium">Inter</p>
          <p class="font-mono text-[11px] text-gray-500 mb-4">--font-inter</p>
          <p class="font-sans text-base text-gray-600 leading-relaxed">
            ABCDEFGHIJKLMNÑOPQRSTUVWXYZ<br />
            abcdefghijklmnñopqrstuvwxyz<br />
            0123456789 &amp;.,!?¿—
          </p>
          <p class="text-[11px] text-gray-500 mt-4">Pesos: 300, 400, 500, 600, 700</p>
          <p class="text-[11px] text-gray-500 mt-1"><strong class="font-medium text-gray-700">Uso:</strong> body, nav, botones, labels, captions, project meta.</p>
        </div>
      </div>

      <!-- Jerarquía -->
      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-8">Jerarquía</h3>
      <div class="space-y-10 mb-20">

        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-12 items-end border-b border-gray-100 pb-10">
          <div>
            <h1 class="font-serif italic font-medium text-6xl md:text-8xl leading-[0.95] tracking-tight text-gray-900">Trabajemos</h1>
          </div>
          <div class="md:text-right space-y-1">
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold">H1 Hero</p>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">font-serif italic font-medium</code>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">text-6xl md:text-8xl</code>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">leading-[0.95]</code>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-12 items-end border-b border-gray-100 pb-10">
          <div>
            <h2 class="font-serif italic font-medium text-4xl md:text-5xl leading-tight text-gray-900">¡Qué bueno verte por aquí!</h2>
          </div>
          <div class="md:text-right space-y-1">
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold">H1 About</p>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">font-serif italic</code>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">text-4xl md:text-5xl</code>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">leading-tight</code>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-12 items-end border-b border-gray-100 pb-10">
          <div>
            <h3 class="font-serif italic font-medium text-3xl md:text-5xl leading-[1.1] text-gray-900">Featured project</h3>
          </div>
          <div class="md:text-right space-y-1">
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold">H2 Destacado</p>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">text-3xl md:text-5xl</code>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">italic font-serif</code>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-12 items-end border-b border-gray-100 pb-10">
          <div>
            <p class="text-[11px] font-bold uppercase tracking-[0.25em] text-[#E0A4B0]">Proyecto destacado</p>
          </div>
          <div class="md:text-right space-y-1">
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold">Eyebrow / Tag</p>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">text-[11px] font-bold</code>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">uppercase tracking-[0.25em]</code>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-12 items-end border-b border-gray-100 pb-10">
          <div class="max-w-xl">
            <p class="text-xl italic font-serif font-light text-gray-600 leading-relaxed">
              ¡Hola! Soy Jessica — pero todos me llaman Jeka. Diseño experiencias que conecten con las personas.
            </p>
          </div>
          <div class="md:text-right space-y-1">
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold">Body editorial</p>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">text-xl italic font-serif</code>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">font-light leading-relaxed</code>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-12 items-end border-b border-gray-100 pb-10">
          <div class="max-w-xl">
            <p class="text-base text-gray-600 leading-relaxed">
              Body técnico para descripciones de proyecto, copys cortos en footer y bloques que requieren legibilidad neutra.
            </p>
          </div>
          <div class="md:text-right space-y-1">
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold">Body principal</p>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">text-base text-gray-600</code>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">leading-relaxed</code>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-12 items-end">
          <div>
            <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">© 2026 Jessica Duran</p>
          </div>
          <div class="md:text-right space-y-1">
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold">Caption / micro</p>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">text-[10px] uppercase</code>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm block">tracking-widest text-gray-400</code>
          </div>
        </div>
      </div>

      <!-- Pesos -->
      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Pesos disponibles</h3>
      <div class="bg-white rounded-[12px] border border-black/5 divide-y divide-gray-100 mb-20">
        {typeWeights.map(w => (
          <div class="grid grid-cols-3 items-center px-6 py-5">
            <p class="font-sans text-2xl text-gray-900" style={`font-weight: ${w.weight};`}>The quick brown fox</p>
            <p class="font-mono text-[11px] text-gray-500">font-weight: {w.weight}</p>
            <p class="text-[11px] uppercase tracking-[0.2em] text-gray-500 font-medium md:text-right">{w.name}</p>
          </div>
        ))}
      </div>

      <!-- Tracking -->
      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Letter spacing personalizado</h3>
      <div class="bg-white rounded-[12px] border border-black/5 divide-y divide-gray-100 mb-20">
        {trackingScale.map(t => (
          <div class="grid grid-cols-1 md:grid-cols-3 items-center px-6 py-5 gap-4">
            <p class="text-xs font-bold uppercase text-gray-900" style={`letter-spacing: ${t.value};`}>JESSICA DURAN</p>
            <code class="font-mono text-[11px] bg-gray-100 px-2 py-1 rounded-sm w-fit">tracking-[{t.value}]</code>
            <p class="text-[11px] text-gray-500 md:text-right">{t.use}</p>
          </div>
        ))}
      </div>

      <!-- Reglas -->
      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Reglas de uso</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-[12px] p-6 border border-black/5">
          <p class="text-[11px] uppercase tracking-[0.2em] text-[#E0A4B0] font-bold mb-3">Usa serif italic cuando…</p>
