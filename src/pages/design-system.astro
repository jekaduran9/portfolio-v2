        <p class="text-base text-gray-600 leading-relaxed max-w-xl mt-4">
          La unidad base de Tailwind es <code class="font-mono text-[12px] bg-gray-100 px-1 py-0.5 rounded-sm">0.25rem (4px)</code>. El portfolio usa una escala consistente y respira con generosidad — secciones grandes con <code class="font-mono text-[12px] bg-gray-100 px-1 py-0.5 rounded-sm">py-24 md:py-32</code>.
        </p>
      </div>

      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Escala de espacio</h3>
      <div class="bg-white rounded-[12px] border border-black/5 p-8 mb-16 overflow-x-auto">
        <div class="space-y-3 min-w-fit">
          {spacingScale.map(s => (
            <div class="flex items-center gap-6">
              <code class="font-mono text-[11px] bg-gray-100 px-2 py-1 rounded-sm w-20 shrink-0">{s.token}</code>
              <span class="text-[11px] text-gray-500 w-12 shrink-0">{s.px}px</span>
              <div class="bg-[#E0A4B0] h-3 rounded-sm" style={`width: ${s.px}px;`}></div>
            </div>
          ))}
        </div>
      </div>

      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Container widths</h3>
      <div class="bg-white rounded-[12px] border border-black/5 p-8 mb-16 space-y-4 overflow-x-auto">
        {containers.map(c => (
          <div class="flex items-center gap-6 min-w-fit">
            <code class="font-mono text-[11px] bg-gray-100 px-2 py-1 rounded-sm w-28 shrink-0">{c.token}</code>
            <span class="text-[11px] text-gray-500 w-16 shrink-0">{c.px}px</span>
            <div class="bg-gray-200 h-6 rounded-sm" style={`width: ${Math.min(c.px / 2, 640)}px;`}></div>
            <span class="text-[11px] text-gray-500">{c.use}</span>
          </div>
        ))}
        <p class="text-[11px] text-gray-500 italic pt-2 border-t border-gray-100">Anchos representados a 50% para caber en pantalla.</p>
      </div>

      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Border radius</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
        {radii.map(r => (
          <div>
            <div class="aspect-square bg-[#E0A4B0]/30 border border-[#E0A4B0]/40 mb-3" style={`border-radius: ${r.value};`}></div>
            <code class="font-mono text-[11px] bg-gray-100 px-1.5 py-0.5 rounded-sm inline-block mb-1">{r.token}</code>
            <p class="text-[11px] text-gray-500 leading-snug">{r.use}</p>
          </div>
        ))}
      </div>

      <h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-6">Grid de proyectos</h3>
      <div class="bg-white rounded-[12px] border border-black/5 p-8 mb-16">
