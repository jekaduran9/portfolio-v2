          <code class="font-mono text-[11px] bg-gray-100 px-2 py-1 rounded-sm">gap-6 md:gap-10</code>
          <code class="font-mono text-[11px] bg-gray-100 px-2 py-1 rounded-sm">aspect-[4/5]</code>
