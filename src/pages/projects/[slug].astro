---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => {
    return data.lang === 'es';
  });
  
  return projects.map((project, index) => {
    return {
      params: { slug: project.slug },
      props: { 
        project,
        prev: index > 0 ? projects[index - 1] : null,
        next: index < projects.length - 1 ? projects[index + 1] : null
      },
    };
  });
}

const { project, prev, next } = Astro.props;
const { Content } = await project.render();
const { title, description, role, tools, type, heroVideo, heroImage, heroAspect } = project.data;
const heroVideoPath = heroVideo?.startsWith('/') ? `${import.meta.env.BASE_URL}${heroVideo}` : heroVideo;
const heroImagePath = heroImage?.startsWith('/') ? `${import.meta.env.BASE_URL}${heroImage}` : heroImage;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<BaseLayout title={title} description={description}>
	<!-- Project Hero -->
	<header class="bg-[#F9F8F3] py-24 md:py-32 border-b border-black/5">
		<div class="max-w-7xl mx-auto px-6">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
				<div class="space-y-8">
					<div class="space-y-4">
						<span class="text-xs uppercase tracking-widest text-gray-400 font-bold">{type}</span>
						<h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-tight uppercase">{title}</h1>
						<p class="text-[16px] text-gray-800 leading-relaxed max-w-xl font-medium">{description}</p>
					</div>
					
					<div class="grid grid-cols-2 gap-8 pt-8 border-t border-gray-200">
						<div>
							<h3 class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-2">{t('project.role')}</h3>
							<p class="text-sm font-medium">{role}</p>
						</div>
						<div>
							<h3 class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-2">{t('project.tools')}</h3>
							<p class="text-sm font-medium">{tools.join(', ')}</p>
						</div>
					</div>
				</div>
				<div class={`${heroAspect} bg-gray-200 overflow-hidden flex items-center justify-center text-gray-400 font-serif italic text-xl`}>
					{heroVideoPath ? (
						<video src={heroVideoPath} class="w-full h-full object-cover" autoplay loop muted playsinline></video>
					) : heroImagePath ? (
						<img src={heroImagePath} alt={title} class="w-full h-full object-cover" />
					) : (
						<span>Hero Image Mockup</span>
					)}
				</div>
			</div>
		</div>
	</header>

	<!-- Content -->
	<article class="max-w-6xl mx-auto px-6 py-24">
		<div class="prose prose-lg prose-gray max-w-none 
			prose-headings:font-medium prose-headings:tracking-tight
			prose-h1:text-4xl prose-h2:text-3xl prose-h3:text-2xl
			prose-p:text-gray-600 prose-p:leading-relaxed
			prose-li:text-gray-600 prose-img:rounded-none">
			<Content />
		</div>
	</article>

	<!-- Project Navigation -->
	<nav class="border-t border-gray-100">
		<div class="max-w-7xl mx-auto px-6 grid grid-cols-2 divide-x divide-gray-100">
			<div class="flex items-center">
				{prev && (
					<a href={translatePath(`/projects/${prev.slug}`)} class="w-full py-16 hover:bg-gray-50 transition-colors group flex flex-col items-start px-4">
						<span class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-4">{t('project.prev')}</span>
						<span class="text-xl font-medium group-hover:underline underline-offset-4">{prev.data.title}</span>
					</a>
				)}
			</div>
			
			<div class="flex items-center">
				{next && (
					<a href={translatePath(`/projects/${next.slug}`)} class="w-full py-16 hover:bg-gray-50 transition-colors group flex flex-col items-end px-4 text-right">
						<span class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-4">{t('project.next')}</span>
						<span class="text-xl font-medium group-hover:underline underline-offset-4">{next.data.title}</span>
					</a>
				)}
			</div>
		</div>
	</nav>
</BaseLayout>
