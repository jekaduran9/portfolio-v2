---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';
import PortfolioByJekaCover from '../../components/covers/PortfolioByJekaCover.astro';

const customCovers: Record<string, any> = {
  'portfolio-by-jeka': PortfolioByJekaCover,
};

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => {
    return data.lang === 'es';
  });

  const sortedProjects = projects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const total = sortedProjects.length;

  return sortedProjects.map((project, index) => {
    return {
      params: { slug: project.slug },
      props: {
        project,
        prev: sortedProjects[(index - 1 + total) % total],
        next: sortedProjects[(index + 1) % total]
      },
    };
  });
}

const { project, prev, next } = Astro.props;
const { Content } = await project.render();
const { title, description, role, tools, type, heroVideo, heroImage, heroAspect } = project.data;
const heroVideoPath = heroVideo?.startsWith('/') ? `${import.meta.env.BASE_URL}${heroVideo}` : heroVideo;
const heroImagePath = heroImage?.startsWith('/') ? `${import.meta.env.BASE_URL}${heroImage}` : heroImage;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const sparklePath = 'M16 1.5 C16.6 11.2 20.8 15.4 30.5 16 C20.8 16.6 16.6 20.8 16 30.5 C15.4 20.8 11.2 16.6 1.5 16 C11.2 15.4 15.4 11.2 16 1.5 Z';
---

<BaseLayout title={title} description={description}>
	<!-- Project Hero — editorial style matching /design-system -->
	<header class="bg-[#F9F8F3] py-20 md:py-28 border-b border-black/5">
		<div class="max-w-7xl mx-auto px-6">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
				<div class="space-y-10">
					<div>
						<span class="text-[10px] md:text-xs uppercase tracking-[0.3em] text-gray-400 font-bold block mb-6">
							{type}
						</span>
						<h1 class="font-serif italic font-medium text-5xl md:text-7xl lg:text-8xl leading-[0.95] tracking-tight text-gray-900 lowercase">
							{title}<svg class="inline-block w-5 h-5 md:w-7 md:h-7 ml-2 align-top mt-2 md:mt-4 text-[#E0A4B0]" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d={sparklePath} /></svg>
						</h1>
						<p class="text-lg md:text-xl italic font-serif font-light text-gray-600 leading-relaxed max-w-xl mt-8">
							{description}
						</p>
					</div>

					<div class="grid grid-cols-2 gap-8 pt-8 border-t border-black/5">
						<div>
							<h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-3">{t('project.role')}</h3>
							<p class="text-sm text-gray-700">{role}</p>
						</div>
						<div>
							<h3 class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-3">{t('project.tools')}</h3>
							<p class="text-sm text-gray-700">{tools.join(', ')}</p>
						</div>
					</div>
				</div>
				<div class={`${heroAspect ?? 'aspect-[4/3]'} rounded-[12px] bg-gray-200 overflow-hidden flex items-center justify-center text-gray-400 font-serif italic text-xl`}>
					{(() => {
						const HeroCover = customCovers[project.slug];
						if (HeroCover) return <HeroCover size="lg" />;
						if (heroVideoPath) return <video src={heroVideoPath} class="w-full h-full object-cover" autoplay loop muted playsinline></video>;
						if (heroImagePath) return <img src={heroImagePath} alt={title} class="w-full h-full object-cover" />;
						return <span>Hero Image Mockup</span>;
					})()}
				</div>
			</div>
		</div>
	</header>

	<!-- Content — editorial prose with auto-numbered H2 sections -->
	<article class="max-w-7xl mx-auto px-6 py-16 md:py-24">
		<div class="case-study-prose">
			<Content />
		</div>
	</article>

	<!-- Project Navigation -->
	<nav class="border-t border-gray-100">
		<div class="max-w-7xl mx-auto px-6 grid grid-cols-2 divide-x divide-gray-100">
			<div class="flex items-center">
				{prev && (
					<a href={translatePath(`/projects/${prev.slug}`)} class="w-full py-16 group flex flex-col items-start px-4">
						<span class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-4">{t('project.prev')}</span>
						<span class="font-serif italic text-2xl md:text-3xl font-medium text-gray-900 lowercase inline-block transition-all duration-300 ease-out group-hover:text-[#E0A4B0] group-hover:-translate-x-2">{prev.data.title}</span>
					</a>
				)}
			</div>
			<div class="flex items-center">
				{next && (
					<a href={translatePath(`/projects/${next.slug}`)} class="w-full py-16 group flex flex-col items-end px-4 text-right">
						<span class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-bold mb-4">{t('project.next')}</span>
						<span class="font-serif italic text-2xl md:text-3xl font-medium text-gray-900 lowercase inline-block transition-all duration-300 ease-out group-hover:text-[#E0A4B0] group-hover:translate-x-2">{next.data.title}</span>
					</a>
				)}
			</div>
		</div>
	</nav>
</BaseLayout>

