---
import '../styles/global.css';
import CustomCursor from '../components/CustomCursor.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath, getCleanPathname } from '../i18n/utils';

interface Props {
	title: string;
	description?: string;
	hideFooterCta?: boolean;
}

const { title, description = "Product Designer & UX/UI Designer Portfolio", hideFooterCta = false } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const cleanPathname = getCleanPathname(Astro.url);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
		<link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Jessica Duran</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#F9F8F3] text-gray-900 font-sans selection:bg-black selection:text-white">
		<header class="fixed top-0 left-0 w-full z-50 bg-[#F9F8F3]/80 backdrop-blur-md border-b border-black/5">
			<nav class="max-w-7xl mx-auto px-6 h-20 flex items-center">
				<div class="flex-1">
					<a href={translatePath('/')} class="hover:opacity-70 transition-opacity inline-block">
						<img src={`${import.meta.env.BASE_URL}/logo-byjeka.png`} alt="Jessica Duran Logo" class="h-10 w-auto object-contain" />
					</a>
				</div>

				<ul class="hidden md:flex items-center gap-10 text-xs font-bold tracking-[0.15em] uppercase">
					<li><a href={translatePath('/#projects')} class="hover:text-gray-500 transition-colors">{t('nav.projects')}</a></li>
					<li><a href={translatePath('/about')} class="hover:text-gray-500 transition-colors">{t('nav.about')}</a></li>
					<li><a href={translatePath('/contact')} class="hover:text-gray-500 transition-colors">{t('nav.contact')}</a></li>
				</ul>

				<div class="flex-1 flex items-center justify-end gap-6 md:gap-10">
					<div class="hidden lg:flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
						</span>
						{t('nav.status')}
					</div>
					<div class="hidden md:flex gap-2 text-xs font-bold uppercase tracking-widest border-l border-black/10 pl-10">
						<a href={translatePath(cleanPathname, 'es')} class={lang === 'es' ? 'text-black' : 'text-gray-400 hover:text-black'}>ES</a>
						<span class="text-gray-300">/</span>
						<a href={translatePath(cleanPathname, 'en')} class={lang === 'en' ? 'text-black' : 'text-gray-400 hover:text-black'}>EN</a>
					</div>

					<button
						id="menu-toggle"
						type="button"
						class="md:hidden relative w-10 h-10 -mr-2 flex flex-col items-center justify-center gap-[5px] text-black"
						aria-label={lang === 'es' ? 'Abrir menú' : 'Open menu'}
						aria-expanded="false"
						aria-controls="mobile-menu"
					>
						<span class="hamburger-line block w-6 h-[1.5px] bg-current transition-transform duration-300 ease-out"></span>
						<span class="hamburger-line block w-6 h-[1.5px] bg-current transition-transform duration-300 ease-out"></span>
					</button>
				</div>
			</nav>
		</header>

		<!-- Mobile menu overlay -->
		<div
			id="mobile-menu"
			class="md:hidden fixed inset-0 z-40 bg-[#F9F8F3] opacity-0 invisible transition-[opacity,visibility] duration-500 ease-out"
			aria-hidden="true"
		>
			<div class="h-full flex flex-col px-6 pt-28 pb-10 max-w-md mx-auto">
				<span class="text-[10px] font-bold uppercase tracking-[0.35em] text-gray-400 mb-10">
					{lang === 'es' ? 'Navegación' : 'Navigation'}
				</span>

				<ul class="flex-1 flex flex-col">
					{[
						{ label: t('nav.home'), href: translatePath('/'), num: '01', match: '/' },
						{ label: t('nav.projects'), href: translatePath('/#projects'), num: '02', match: '/#projects' },
						{ label: t('nav.about'), href: translatePath('/about'), num: '03', match: '/about' },
						{ label: t('nav.contact'), href: translatePath('/contact'), num: '04', match: '/contact' },
					].map((item) => {
						const isActive = cleanPathname === item.match || (item.match === '/#projects' && cleanPathname === '/');
						return (
							<li class="border-b border-black/10 group">
								<a
									href={item.href}
									class={`menu-link flex items-baseline gap-5 py-5 transition-colors duration-300 ${isActive ? 'text-[#E0A4B0]' : 'text-gray-900 group-hover:text-[#E0A4B0]'}`}
								>
									<span class="text-[10px] font-bold uppercase tracking-[0.3em] text-gray-400 group-hover:text-[#E0A4B0] transition-colors duration-300">{item.num}</span>
									<span class="text-4xl font-serif italic font-medium leading-none">{item.label}</span>
								</a>
							</li>
						);
					})}
				</ul>

				<div class="mt-10 space-y-5">
					<div class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.3em] text-gray-400">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
						</span>
						{t('nav.status')}
					</div>
					<div class="flex items-center justify-between pt-5 border-t border-black/10">
						<a href="mailto:jekaduran9@gmail.com" class="text-sm font-medium tracking-tight underline underline-offset-4 decoration-gray-300 hover:decoration-[#E0A4B0] hover:text-[#E0A4B0] transition-colors">jekaduran9@gmail.com</a>
						<div class="flex gap-2 text-xs font-bold uppercase tracking-widest">
							<a href={translatePath(cleanPathname, 'es')} class={lang === 'es' ? 'text-black' : 'text-gray-400 hover:text-black'}>ES</a>
							<span class="text-gray-300">/</span>
							<a href={translatePath(cleanPathname, 'en')} class={lang === 'en' ? 'text-black' : 'text-gray-400 hover:text-black'}>EN</a>
						</div>
					</div>
				</div>
			</div>
		</div>

		<main class="pt-20">
			<slot />
		</main>

		<footer class="bg-[#F9F8F3] py-20 border-t border-black/5">
			<div class="max-w-7xl mx-auto px-6">
				{!hideFooterCta && (
					<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
						<div>
							<h2 class="text-2xl font-medium mb-4">{t('footer.cta')}</h2>
							<p class="text-gray-500 max-w-sm">{t('footer.description')}</p>
						</div>
						<div class="flex gap-8">
							<a href="mailto:jekaduran9@gmail.com" class="text-lg font-medium hover:underline underline-offset-4 tracking-tight">{t('footer.email')}</a>
							<a href="https://linkedin.com/in/jessicaduran" class="text-lg font-medium hover:underline underline-offset-4 tracking-tight">{t('footer.linkedin')}</a>
						</div>
					</div>
				)}
				<div class:list={["pt-8 border-t border-gray-50 flex justify-between items-center text-xs text-gray-400 uppercase tracking-widest", hideFooterCta ? "" : "mt-20"]}>
					<p>© 2026 Jessica Duran</p>
					<p>Product Designer & UX/UI</p>
				</div>
			</div>
		</footer>
		<CustomCursor />

		<script>
			const toggle = document.getElementById('menu-toggle');
			const menu = document.getElementById('mobile-menu');
			const root = document.documentElement;

			const setOpen = (open: boolean) => {
				root.classList.toggle('menu-open', open);
				toggle?.setAttribute('aria-expanded', String(open));
				menu?.setAttribute('aria-hidden', String(!open));
				toggle?.setAttribute(
					'aria-label',
					open
						? (root.lang === 'es' ? 'Cerrar menú' : 'Close menu')
						: (root.lang === 'es' ? 'Abrir menú' : 'Open menu')
				);
			};

			toggle?.addEventListener('click', () => {
				setOpen(!root.classList.contains('menu-open'));
			});

			menu?.querySelectorAll('a').forEach((link) => {
				link.addEventListener('click', () => setOpen(false));
			});

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && root.classList.contains('menu-open')) setOpen(false);
			});
		</script>
	</body>
</html>

<style is:global>
	:root {
		--font-sans: 'Inter', sans-serif;
		--font-serif: 'Cormorant Garamond', serif;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: var(--font-sans);
	}

	.font-serif {
		font-family: var(--font-serif);
	}

	.menu-open {
		overflow: hidden;
	}
	.menu-open body {
		overflow: hidden;
	}
	.menu-open #mobile-menu {
		opacity: 1;
		visibility: visible;
	}
	.menu-open .hamburger-line:first-child {
		transform: translateY(3.5px) rotate(45deg);
	}
	.menu-open .hamburger-line:last-child {
		transform: translateY(-3.5px) rotate(-45deg);
	}
</style>
